<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Family Health Agent</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #F0F4F8;
      --surface: #FFFFFF;
      --surface-2: #F8FAFC;
      --border: #E2E8F0;
      --border-soft: #EEF2F7;
      --ink: #0F172A;
      --ink-2: #334155;
      --ink-3: #64748B;
      --ink-4: #94A3B8;
      --blue: #2563EB;
      --blue-dark: #1D4ED8;
      --blue-soft: #EFF6FF;
      --blue-mid: #BFDBFE;
      --green: #059669;
      --green-soft: #ECFDF5;
      --green-mid: #A7F3D0;
      --red: #DC2626;
      --red-soft: #FEF2F2;
      --red-mid: #FECACA;
      --amber: #D97706;
      --amber-soft: #FFFBEB;
      --amber-mid: #FDE68A;
      --purple: #7C3AED;
      --purple-soft: #F5F3FF;
      --purple-mid: #DDD6FE;
      --teal: #0891B2;
      --teal-soft: #ECFEFF;
      --teal-mid: #A5F3FC;
      --rose: #E11D48;
      --rose-soft: #FFF1F2;
      --shadow-xs: 0 1px 2px rgba(15,23,42,0.04);
      --shadow-sm: 0 1px 3px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04);
      --shadow: 0 4px 6px rgba(15,23,42,0.04), 0 2px 4px rgba(15,23,42,0.03);
      --radius: 14px;
      --radius-sm: 10px;
      --radius-xs: 6px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--ink); min-height: 100vh; -webkit-font-smoothing: antialiased; }

    .app { max-width: 700px; margin: 0 auto; padding: 0 0 90px; display: flex; flex-direction: column; min-height: 100vh; }

    /* HEADER */
    .header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 1rem 1.25rem 0.875rem; position: sticky; top: 0; z-index: 100; box-shadow: var(--shadow-xs); }
    .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.875rem; }
    .logo-wrap { display: flex; align-items: center; gap: 9px; }
    .logo { width: 34px; height: 34px; background: linear-gradient(135deg, var(--blue) 0%, var(--blue-dark) 100%); border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 18px; box-shadow: var(--shadow-sm); }
    .logo-text h1 { font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.02em; }
    .logo-text p { font-size: 10px; color: var(--ink-3); font-weight: 400; }
    .clear-btn { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 500; color: var(--ink-3); background: var(--surface-2); border: 1px solid var(--border); padding: 5px 11px; border-radius: 20px; cursor: pointer; transition: all 0.15s; }
    .clear-btn:hover { background: var(--border); color: var(--ink-2); }

    /* PERSON SWITCHER */
    .person-switcher { display: flex; gap: 6px; }
    .person-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 8px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--border); background: var(--surface-2); cursor: pointer; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500; color: var(--ink-3); transition: all 0.2s; }
    .avatar { width: 22px; height: 22px; border-radius: 50%; background: var(--border); color: var(--ink-3); font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .person-btn.active { border-color: var(--blue); background: var(--blue-soft); color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
    .person-btn.active .avatar { background: var(--blue); color: white; }

    /* QUICK CHIPS */
    .quick-wrap { padding: 0.75rem 1.25rem; display: flex; gap: 6px; overflow-x: auto; -ms-overflow-style: none; scrollbar-width: none; }
    .quick-wrap::-webkit-scrollbar { display: none; }
    .qchip { font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; padding: 6px 13px; border-radius: 20px; border: 1px solid var(--border); background: var(--surface); color: var(--ink-2); cursor: pointer; white-space: nowrap; transition: all 0.15s; }
    .qchip:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-soft); }

    /* CHAT */
    .chat { flex: 1; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

    /* MESSAGES */
    .msg-user { align-self: flex-end; max-width: 72%; background: var(--blue); color: white; padding: 10px 15px; border-radius: 18px 18px 4px 18px; font-size: 14px; line-height: 1.5; box-shadow: var(--shadow-sm); }
    .msg-agent { align-self: flex-start; width: 100%; }
    .agent-bubble { background: var(--surface); border: 1px solid var(--border); border-radius: 4px 18px 18px 18px; padding: 1rem 1.125rem; box-shadow: var(--shadow-sm); }
    .system-note { text-align: center; font-size: 11px; color: var(--ink-4); padding: 2px 0; }

    /* THINKING */
    .thinking-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 4px 18px 18px 18px; padding: 12px 16px; display: flex; align-items: center; gap: 10px; color: var(--ink-3); font-size: 13px; }
    .dots { display: flex; gap: 3px; }
    .dots span { width: 5px; height: 5px; border-radius: 50%; background: var(--blue); animation: blink 1.4s ease-in-out infinite; }
    .dots span:nth-child(2) { animation-delay: 0.2s; }
    .dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes blink { 0%,60%,100% { opacity:0.2;transform:scale(0.8); } 30% { opacity:1;transform:scale(1); } }

    /* ═══ MEDICINE RESPONSE ═══ */
    .med-response-header {
      font-family: 'Crimson Pro', serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .med-response-sub {
      font-size: 12px;
      color: var(--ink-3);
      margin-bottom: 14px;
      font-weight: 400;
    }

    .condition-group {
      margin-bottom: 14px;
    }
.condition-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: var(--radius-xs);
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  border-left: 4px solid transparent;
  box-shadow: var(--shadow-xs);
}

.cond-psychiatric { background: var(--purple-soft); color: var(--purple); border-left-color: var(--purple); }
.cond-diabetes    { background: var(--blue-soft);   color: var(--blue);   border-left-color: var(--blue); }
.cond-bp          { background: var(--rose-soft);   color: var(--rose);   border-left-color: var(--rose); }
.cond-thyroid     { background: var(--teal-soft);   color: var(--teal);   border-left-color: var(--teal); }
.cond-kidney      { background: var(--amber-soft);  color: var(--amber);  border-left-color: var(--amber); }
.cond-cholesterol { background: var(--green-soft);  color: var(--green);  border-left-color: var(--green); }
.cond-anxiety     { background: var(--purple-soft); color: var(--purple); border-left-color: var(--purple); }
.cond-vitamins    { background: var(--green-soft);  color: var(--green);  border-left-color: var(--green); }
.cond-general     { background: var(--surface-2);   color: var(--ink-3);  border-left-color: var(--border); border: 1px solid var(--border); }
  
    .cond-count {
      margin-left: auto;
      font-size: 10px;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 10px;
      background: rgba(0,0,0,0.08);
    }

    .med-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 12px;
      margin-bottom: 5px;
      background: var(--surface);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-sm);
      border-left: 3px solid var(--border);
      transition: all 0.15s;
    }
    .med-item:hover {
      box-shadow: var(--shadow);
      transform: translateX(2px);
    }
    .med-item:last-child { margin-bottom: 0; }

    .med-badge-num {
      min-width: 22px;
      height: 22px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
      color: white;
    }

    .num-psychiatric { background: var(--purple); }
    .num-diabetes { background: var(--blue); }
    .num-bp { background: var(--rose); }
    .num-thyroid { background: var(--teal); }
    .num-kidney { background: var(--amber); }
    .num-cholesterol { background: var(--green); }
    .num-anxiety { background: var(--purple); }
    .num-vitamins { background: var(--green); }
    .num-general { background: var(--ink-3); }

    .med-body { flex: 1; }

    .med-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 3px;
      line-height: 1.3;
    }

    .med-freq {
      font-size: 12px;
      color: var(--ink-3);
      margin-bottom: 5px;
      line-height: 1.4;
    }

    .med-chips { display: flex; flex-wrap: wrap; gap: 4px; }

    .chip {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      gap: 3px;
    }

    .chip-morning { background: #FEF9C3; color: #92400E; }
    .chip-night { background: #EDE9FE; color: #5B21B6; }
    .chip-afternoon { background: #DBEAFE; color: #1E40AF; }
    .chip-empty { background: #F0FDF4; color: #065F46; }
    .chip-sos { background: var(--red-soft); color: var(--red); }
    .chip-monthly { background: var(--teal-soft); color: var(--teal); }
    .chip-twice { background: var(--surface-2); color: var(--ink-2); border: 1px solid var(--border); }

    .med-summary-bar {
      margin-top: 12px;
      padding: 10px 14px;
      background: linear-gradient(135deg, var(--blue-soft) 0%, #E0EFFE 100%);
      border: 1px solid var(--blue-mid);
      border-radius: var(--radius-sm);
      font-size: 12px;
      color: var(--blue-dark);
      font-weight: 500;
      line-height: 1.5;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }

    /* TEST RESULTS */
    .test-header-line {
      font-family: 'Crimson Pro', serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 12px;
      letter-spacing: -0.01em;
    }

    .attention-banner {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: var(--red-soft);
      border: 1px solid var(--red-mid);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      margin-bottom: 12px;
    }

    .attention-text { font-size: 12px; font-weight: 600; color: var(--red); line-height: 1.5; }
    .attention-text span { font-weight: 400; color: #7f1d1d; }

    .test-card {
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      margin-bottom: 6px;
      border: 1px solid var(--border-soft);
      border-left: 3px solid var(--border);
      background: var(--surface-2);
    }

    .test-card.high { background: var(--red-soft); border-color: var(--red-mid); border-left-color: var(--red); }
    .test-card.low { background: var(--amber-soft); border-color: var(--amber-mid); border-left-color: var(--amber); }
    .test-card.normal { background: var(--green-soft); border-color: var(--green-mid); border-left-color: var(--green); }

    .test-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
    .test-num-name { display: flex; align-items: center; gap: 8px; }
    .test-idx { width: 20px; height: 20px; border-radius: 50%; background: var(--border); color: var(--ink-3); font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .test-card.high .test-idx { background: var(--red-mid); color: var(--red); }
    .test-card.low .test-idx { background: var(--amber-mid); color: var(--amber); }
    .test-card.normal .test-idx { background: var(--green-mid); color: var(--green); }
    .test-name { font-size: 13px; font-weight: 600; color: var(--ink); }
    .test-status-badge { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; text-transform: uppercase; letter-spacing: 0.05em; flex-shrink: 0; }
    .badge-high { background: var(--red-mid); color: var(--red); }
    .badge-low { background: var(--amber-mid); color: var(--amber); }
    .badge-normal { background: var(--green-mid); color: var(--green); }
    .test-value { font-size: 13px; font-weight: 500; color: var(--ink-2); margin-bottom: 3px; }
    .test-meta { font-size: 11px; color: var(--ink-3); }

    /* INFO CARD */
    .resp-title { font-family: 'Crimson Pro', serif; font-size: 17px; font-weight: 600; color: var(--ink); margin-bottom: 12px; }
    .info-card { background: var(--surface-2); border: 1px solid var(--border-soft); border-radius: var(--radius-sm); overflow: hidden; }
    .info-row { display: flex; gap: 10px; padding: 9px 12px; border-bottom: 1px solid var(--border-soft); align-items: center; }
    .info-row:last-child { border-bottom: none; }
    .info-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-4); min-width: 90px; flex-shrink: 0; }
    .info-value { font-size: 13px; color: var(--ink-2); flex: 1; }
    .info-value.overdue { color: var(--red); font-weight: 600; }

    .summary-bar { margin-top: 12px; padding: 10px 12px; background: var(--blue-soft); border: 1px solid var(--blue-mid); border-radius: var(--radius-sm); font-size: 12px; color: var(--blue-dark); font-weight: 500; line-height: 1.5; }

    .plain-text { font-size: 14px; color: var(--ink-2); line-height: 1.7; }
    .plain-text div { margin-bottom: 5px; }

    .error-msg { color: var(--red); font-size: 13px; margin-bottom: 8px; }
    .retry-btn { font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; padding: 6px 14px; border: 1px solid var(--red); border-radius: 16px; background: white; color: var(--red); cursor: pointer; }

    /* INPUT */
    .input-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--surface); border-top: 1px solid var(--border); padding: 0.75rem 1.25rem; z-index: 100; }
    .input-inner { max-width: 700px; margin: 0 auto; display: flex; gap: 8px; align-items: center; }
    .input-field { flex: 1; background: var(--surface-2); border: 1.5px solid var(--border); border-radius: 24px; padding: 11px 16px; font-family: 'Inter', sans-serif; font-size: 14px; color: var(--ink); outline: none; transition: border-color 0.15s; }
    .input-field::placeholder { color: var(--ink-4); }
    .input-field:focus { border-color: var(--blue); }
    .send-btn { width: 44px; height: 44px; border-radius: 50%; background: var(--blue); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s; box-shadow: var(--shadow-sm); }
    .send-btn:hover { background: var(--blue-dark); transform: scale(1.05); }
    .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .send-btn svg { width: 16px; height: 16px; fill: white; }

    @media (max-width: 480px) {
      .header { padding: 0.875rem 1rem 0.75rem; }
      .chat { padding: 0.875rem 1rem; }
      .quick-wrap { padding: 0.625rem 1rem; }
      .input-bar { padding: 0.625rem 1rem; }
    }
  </style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="header-top">
      <div class="logo-wrap">
        <div class="logo">🏥</div>
        <div class="logo-text">
          <h1>Family Health</h1>
          <p>AI-powered health records</p>
        </div>
      </div>
      <button class="clear-btn" onclick="clearChat()">Clear chat</button>
    </div>
    <div class="person-switcher">
      <button class="person-btn active" onclick="setPerson('Father',this)">
        <span class="avatar">P</span> Father
      </button>
      <button class="person-btn" onclick="setPerson('Mother',this)">
        <span class="avatar">M</span> Mother
      </button>
    </div>
  </div>

  <div class="quick-wrap">
    <button class="qchip" onclick="ask('What medicines is '+person+' taking?')">💊 Medicines</button>
    <button class="qchip" onclick="ask('Last test results for '+person)">🧪 Last tests</button>
    <button class="qchip" onclick="ask('Upcoming follow-ups for '+person)">📅 Follow-ups</button>
    <button class="qchip" onclick="ask('Give me a full health summary for '+person)">📋 Summary</button>
    <button class="qchip" onclick="ask('Which tests are abnormal for '+person+'?')">⚠️ Abnormal</button>
  </div>

  <div class="chat" id="chat">
    <div class="msg-agent">
      <div class="agent-bubble" style="background:linear-gradient(135deg,var(--blue) 0%,var(--blue-dark) 100%);border-color:var(--blue);color:white;border-radius:var(--radius)">
        <div style="font-family:'Crimson Pro',serif;font-size:20px;font-weight:600;margin-bottom:5px;letter-spacing:-0.01em">Hello! 👋</div>
        <div style="font-size:13px;opacity:0.9;line-height:1.6">Ask me anything about your family's health — medicines, test results, appointments, or a full health summary. Use the tabs above to switch between Father and Mother.</div>
      </div>
    </div>
  </div>

  <div class="input-bar">
    <div class="input-inner">
      <input class="input-field" id="inp" placeholder="Ask about medicines, tests, follow-ups..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg();}">
      <button class="send-btn" id="sendBtn" onclick="sendMsg()">
        <svg viewBox="0 0 16 16"><path d="M1.5 8L14.5 1.5L10.5 8L14.5 14.5L1.5 8Z"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
const AGENT_URL = 'https://script.google.com/macros/s/AKfycbwEV1IPPw22mNGZoYkqwwiMywB0FJ-VMuxkehpI7HN5bvnMZgLlnU3q4fu_ko-y0eWw/exec';
let person = 'Father';
let lastPerson = 'Father';
let conversationHistory = [];

function setPerson(p, btn) {
  person = p;
  document.querySelectorAll('.person-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if (p !== lastPerson) {
    conversationHistory = [];
    lastPerson = p;
    showNote('Switched to ' + p);
  }
}

function showNote(t) {
  var d = document.createElement('div');
  d.className = 'system-note';
  d.textContent = t;
  document.getElementById('chat').appendChild(d);
}

function clearChat() {
  conversationHistory = [];
  document.getElementById('chat').innerHTML = '';
  showNote('Chat cleared');
}

// ── CONDITION METADATA ─────────────────────────────
var conditionMeta = {
  psychiatric: { icon: '🧠', label: 'Psychiatric & Mental Health', cls: 'cond-psychiatric', numCls: 'num-psychiatric' },
  diabetes:    { icon: '🩸', label: 'Diabetes',                    cls: 'cond-diabetes',    numCls: 'num-diabetes' },
  bp:          { icon: '❤️', label: 'Blood Pressure',              cls: 'cond-bp',          numCls: 'num-bp' },
  thyroid:     { icon: '🦋', label: 'Thyroid',                     cls: 'cond-thyroid',     numCls: 'num-thyroid' },
  kidney:      { icon: '🫘', label: 'Kidney Disease',              cls: 'cond-kidney',      numCls: 'num-kidney' },
  cholesterol: { icon: '🧬', label: 'Cholesterol',                 cls: 'cond-cholesterol', numCls: 'num-cholesterol' },
  anxiety:     { icon: '🧘', label: 'Anxiety & Sleep',             cls: 'cond-anxiety',     numCls: 'num-anxiety' },
  vitamins:    { icon: '💫', label: 'Vitamins & Supplements',      cls: 'cond-vitamins',    numCls: 'num-vitamins' },
  general:     { icon: '💊', label: 'General Health',              cls: 'cond-general',     numCls: 'num-general' }
};

function getConditionKey(text) {
  var t = text.toLowerCase();
  if (/psychiatric|mental|lamotrigine|quetiapine|flupen|lithium|antipsychotic|f31|f32|f33/i.test(t)) return 'psychiatric';
  if (/anxiety|sleep|sertraline|sertima|dayvigo|melocure|melatonin|qutan|insomnia|f41|f51/i.test(t)) return 'anxiety';
  if (/diabetes|insulin|novomix|metformin|linagliptin|gliptin|torglip|gluco|sugar|hba1c/i.test(t)) return 'diabetes';
  if (/blood pressure|bp|hypertension|telmisartan|cilacar|nebistar|cilacal|amlodipine|losartan/i.test(t)) return 'bp';
  if (/thyroid|thyrox|thyronorm|eltroxin|levothyroxine/i.test(t)) return 'thyroid';
  if (/kidney|renal|nefrosave|creatinine|ckd|nephro/i.test(t)) return 'kidney';
  if (/cholesterol|lipid|roseday|zyrova|atorvastatin|rosuvastatin|lipaglyn|dyslipid|triglyceride/i.test(t)) return 'cholesterol';
  if (/vitamin|supplement|calcium|gemcal|van d3|van b12|b12|iron|lohfer|folic|multivitamin|vitavan|gramzero|cranberry/i.test(t)) return 'vitamins';
  return 'general';
}

function getTimingChips(text) {
  var t = text.toLowerCase();
  var chips = [];
  var twice = t.includes('twice') || t.includes('1-0-1') || (t.includes('morning') && t.includes('night') && !t.includes('once'));
  if (twice) {
    chips.push('<span class="chip chip-morning">🌅 Morning</span>');
    chips.push('<span class="chip chip-night">🌙 Night</span>');
    return chips.join('');
  }
  if (t.includes('empty stomach') || t.includes('empty')) chips.push('<span class="chip chip-empty">🍽️ Empty stomach</span>');
  if (t.includes('morning') || t.includes('1-0-0') || t.includes('subah')) chips.push('<span class="chip chip-morning">🌅 Morning</span>');
  if (t.includes('afternoon') || t.includes('noon') || t.includes('0-1-0')) chips.push('<span class="chip chip-afternoon">☀️ Afternoon</span>');
  if (t.includes('night') || t.includes('0-0-1') || t.includes('evening') || t.includes('bedtime') || t.includes('raat')) chips.push('<span class="chip chip-night">🌙 Night</span>');
  if (t.includes('sos') || t.includes('as needed') || t.includes('when required')) chips.push('<span class="chip chip-sos">⚡ SOS</span>');
  if (t.includes('monthly') || t.includes('once a month') || t.includes('60k')) chips.push('<span class="chip chip-monthly">📅 Monthly</span>');
  return chips.join('');
}

// ── MEDICINE RENDERER ─────────────────────────────
function renderMedicines(lines) {
  var headerLine = '';
  var sections = {};
  var sectionOrder = [];
  var currentKey = null;
  var summaryLine = '';

  lines.forEach(function(line) {
    if (/^summary:/i.test(line) || /^all these/i.test(line) || /^all medications/i.test(line)) {
      summaryLine = line;
      return;
    }

    var isHeading = (/^[A-Z][^|]{3,}:?\s*$/.test(line) && !/^[-\u2013\u2014\d*]/.test(line)) ||
      /^(Psychiatric|General|Mental|Diabetes|Thyroid|Kidney|Heart|BP|Anxiety|Sleep|Vitamin|Supplement|Blood|Cholesterol|Medication)/i.test(line);

    if (isHeading) {
      var headText = line.replace(/:$/, '').trim();
      currentKey = getConditionKey(headText);
      if (!sections[currentKey]) {
        sections[currentKey] = [];
        sectionOrder.push(currentKey);
      }
      return;
    }

    var isBullet = /^[-\u2013\u2014*]\s/.test(line);
var isPlainMedLine = currentKey !== null && line.length > 5 && !isHeading;
if (isBullet || isPlainMedLine) {
      if (!currentKey) {
        currentKey = getConditionKey(line);
        if (!sections[currentKey]) { sections[currentKey] = []; sectionOrder.push(currentKey); }
      }
      var itemText = line.replace(/^[-\u2013\u2014*]\s+/, '').trim();
      sections[currentKey].push(itemText);
      return;
    }

    if (!currentKey) headerLine += line + ' ';
  });

  var html = '';
  if (headerLine.trim()) {
    var countMatch = headerLine.match(/\d+/);
    html += '<div class="med-response-header">' + headerLine.trim() + '</div>';
    if (countMatch) html += '<div class="med-response-sub">' + sectionOrder.length + ' condition group' + (sectionOrder.length !== 1 ? 's' : '') + ' · tap a medicine for details</div>';
  }
var borderColors = {
  psychiatric: 'var(--purple)',
  diabetes: 'var(--blue)',
  bp: 'var(--rose)',
  thyroid: 'var(--teal)',
  kidney: 'var(--amber)',
  cholesterol: 'var(--green)',
  anxiety: 'var(--purple)',
  vitamins: 'var(--green)',
  general: 'var(--border)'
};
  
  sectionOrder.forEach(function(key) {
    var meta = conditionMeta[key] || conditionMeta.general;
    var items = sections[key];
    if (!items || items.length === 0) return;

    html += '<div class="condition-group">' +
      '<div class="condition-header ' + meta.cls + '">' +
      '<span>' + meta.icon + '</span>' +
      '<span>' + meta.label + '</span>' +
      '<span class="cond-count">' + items.length + ' medicine' + (items.length > 1 ? 's' : '') + '</span>' +
      '</div>';

    items.forEach(function(item, idx) {
      var di = item.indexOf(' - ');
      var medName = (di > -1 ? item.substring(0, di) : item).trim();
      var medDetail = di > -1 ? item.substring(di + 3).trim() : '';
      var fm = medDetail.match(/\(?for (.+?)\)?\.?$/i);
      var cond = fm ? fm[1].trim() : '';
      var freq = cond ? medDetail.replace(/\(?for .+?\)?\.?$/i, '').replace(/-\s*$/, '').trim() : medDetail;
      var timingHtml = getTimingChips(freq + ' ' + medDetail + ' ' + medName);
      
      html += '<div class="med-item" style="border-left-color:' + (borderColors[key] || 'var(--border)') + '">' +
        '<div class="med-badge-num ' + meta.numCls + '">' + (idx + 1) + '</div>' +
        '<div class="med-body">' +
        '<div class="med-name">' + medName + '</div>' +
        (freq ? '<div class="med-freq">' + freq + '</div>' : '') +
        (timingHtml ? '<div class="med-chips">' + timingHtml + '</div>' : '') +
        '</div></div>';
    });

    html += '</div>';
  });

  if (summaryLine) {
    html += '<div class="med-summary-bar">📊 ' + summaryLine + '</div>';
  }

  return html;
}

// ── MAIN RENDER ───────────────────────────────────
function renderResponse(text) {
  if (!text) return '<div class="plain-text">No response received.</div>';

  text = text
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .trim();

  var lines = text.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l; });
console.log('LINES:', JSON.stringify(lines));

  var hasItems = lines.some(function(l) { return /^[-\u2013\u2014*]\s/.test(l); });
var hasNumbered = lines.some(function(l) { return /^\d+\./.test(l); });

// MEDICINE RESPONSE — trigger if ANY known condition heading + dash items exist
var hasMedHeading = lines.some(function(l) {
  return /^(Psychiatric|Diabetes|Blood Pressure|Thyroid|Kidney|Cholesterol|Anxiety|Vitamins|General Health|Supplements)/i.test(l);
});
var isMedicineResponse = lines.some(function(l) {
  return /medicine|medicines|tablet|taking|active medicines/i.test(l);
});

if ((hasMedHeading && hasItems) || (isMedicineResponse && hasItems)) {
  return renderMedicines(lines);
}
  // MEDICINE RESPONSE — grouped by condition
  if ((hasSections && hasItems) || (isMedicineResponse && hasItems)) {
    return renderMedicines(lines);
  }

  // TEST RESULTS — numbered cards
  if (hasNumbered) {
    var numbered = lines.filter(function(l) { return /^\d+\./.test(l); });
    var sl = lines.find(function(l) { return /^summary:/i.test(l); });
    var firstNum = lines.indexOf(numbered[0]);
    var hdr = firstNum > 0 ? lines.slice(0, firstNum).join(' ') : '';
    var html2 = '';

    var attentionItems = numbered.filter(function(l) {
      return /high|elevated|abnormal|critical/i.test(l);
    }).map(function(l) {
      return l.replace(/^\d+\.\s*/, '').split('|')[0].trim().substring(0, 30);
    });

    if (attentionItems.length > 0) {
      html2 += '<div class="attention-banner">' +
        '<div style="font-size:16px;flex-shrink:0">⚠️</div>' +
        '<div class="attention-text">' + attentionItems.length + ' result' + (attentionItems.length > 1 ? 's' : '') + ' outside normal range<br>' +
        '<span>' + attentionItems.slice(0, 3).join(', ') + '</span></div></div>';
    }

    if (hdr) html2 += '<div class="test-header-line">' + hdr + '</div>';

    numbered.forEach(function(line, idx) {
      var withoutNum = line.replace(/^\d+\.\s*/, '');
      var name, detail, date, status, lab;

      if (withoutNum.includes('|')) {
        var parts = withoutNum.split('|').map(function(p) { return p.trim(); });
        name = parts[0] || '';
        date = parts[1] || '';
        detail = parts[2] || '';
        status = parts[3] || '';
        lab = parts[4] || '';
      } else {
        var di = withoutNum.indexOf(' - ');
        name = (di > -1 ? withoutNum.substring(0, di) : withoutNum).trim();
        detail = di > -1 ? withoutNum.substring(di + 3).trim() : '';
        status = ''; date = ''; lab = '';
      }

      var sLow = status.toLowerCase();
      var cardCls = sLow.includes('high') ? 'test-card high' : sLow.includes('low') ? 'test-card low' : sLow.includes('normal') ? 'test-card normal' : 'test-card';
      var badgeCls = sLow.includes('high') ? 'test-status-badge badge-high' : sLow.includes('low') ? 'test-status-badge badge-low' : sLow.includes('normal') ? 'test-status-badge badge-normal' : '';

      html2 += '<div class="' + cardCls + '">' +
        '<div class="test-top">' +
        '<div class="test-num-name"><div class="test-idx">' + (idx+1) + '</div><div class="test-name">' + name + '</div></div>' +
        (badgeCls ? '<div class="' + badgeCls + '">' + status + '</div>' : '') +
        '</div>' +
        (detail ? '<div class="test-value">' + detail + '</div>' : '') +
        (date ? '<div class="test-meta">📅 ' + date + (lab ? '&nbsp;·&nbsp;🏥 ' + lab : '') + '</div>' : '') +
        '</div>';
    });

    if (sl) html2 += '<div class="summary-bar">📊 ' + sl + '</div>';
    return html2;
  }

  // LABELED CARD — follow-ups
  var labeled = lines.filter(function(l) {
    return /^[A-Za-z ]+:\s*.+/.test(l) && !/^summary:/i.test(l);
  });
  if (labeled.length >= 2) {
    var fLbl = lines.indexOf(labeled[0]);
    var hdr2 = fLbl > 0 ? lines.slice(0, fLbl).join(' ') : '';
    var html3 = hdr2 ? '<div class="resp-title">' + hdr2 + '</div>' : '';
    html3 += '<div class="info-card">';
    labeled.forEach(function(line) {
      var ci = line.indexOf(':');
      var lbl = line.substring(0, ci).trim();
      var val = line.substring(ci+1).trim();
      var vCls = val.toLowerCase().includes('overdue') ? 'info-value overdue' : 'info-value';
      html3 += '<div class="info-row"><div class="info-label">' + lbl + '</div><div class="' + vCls + '">' + val + '</div></div>';
    });
    html3 += '</div>';
    var slc = lines.find(function(l) { return /^summary:/i.test(l); });
    if (slc) html3 += '<div class="summary-bar">📊 ' + slc + '</div>';
    return html3;
  }

  // PLAIN TEXT
  return '<div class="plain-text">' + lines.map(function(l) {
    return '<div>' + l + '</div>';
  }).join('') + '</div>';
}

// ── MESSAGING ─────────────────────────────────────
function addUserMsg(text) {
  var chat = document.getElementById('chat');
  var d = document.createElement('div');
  d.className = 'msg-user';
  d.textContent = text;
  chat.appendChild(d);
  d.scrollIntoView({ behavior: 'smooth' });
}

function addThinking() {
  var chat = document.getElementById('chat');
  var d = document.createElement('div');
  d.className = 'msg-agent';
  d.innerHTML = '<div class="thinking-wrap"><div class="dots"><span></span><span></span><span></span></div>Thinking...</div>';
  chat.appendChild(d);
  d.scrollIntoView({ behavior: 'smooth' });
  return d;
}

function setReply(el, html) {
  el.innerHTML = '<div class="agent-bubble">' + html + '</div>';
  el.scrollIntoView({ behavior: 'smooth' });
}
function validateResponse(data) {
  if (!data) return { valid: false, text: 'No response received.' };
  if (data.status === 'error') return { valid: false, text: 'Agent error. Please try again.' };
  if (!data.answer || typeof data.answer !== 'string') return { valid: false, text: 'Empty response.' };
  var t = data.answer.trim();
  if (t.length < 10) return { valid: false, text: 'Response too short.' };
  return { valid: true, text: t };
}

async function ask(q) {
  document.getElementById('inp').value = q;
  await sendMsg();
}

async function sendMsg() {
  var inp = document.getElementById('inp');
  var q = inp.value.trim();
  if (!q) return;
  inp.value = '';
  var btn = document.getElementById('sendBtn');
  btn.disabled = true;

  conversationHistory.push({ role: 'user', content: q });
  if (conversationHistory.length > 10) conversationHistory = conversationHistory.slice(-10);

  addUserMsg(q);
  var thinkEl = addThinking();

  try {
    var controller = new AbortController();
    var timeout = setTimeout(function() { controller.abort(); }, 20000);

    var r = await fetch(AGENT_URL, {
      method: 'POST',
      body: JSON.stringify({ question: q, person: person, history: conversationHistory.slice(0, -1) }),
      signal: controller.signal
    });
    clearTimeout(timeout);

    if (!r.ok) throw new Error('HTTP ' + r.status);

    var data = await r.json();
    var v = validateResponse(data);

    if (!v.valid) {
      conversationHistory.pop();
      setReply(thinkEl, '<div class="error-msg">' + v.text + '</div><button class="retry-btn" onclick="retryQuestion(\'' + q.replace(/'/g,"\\'") + '\')">Try again</button>');
    } else {
      conversationHistory.push({ role: 'assistant', content: v.text });
      setReply(thinkEl, renderResponse(v.text));
    }
  } catch(e) {
    conversationHistory.pop();
    var msg = e.name === 'AbortError' ? 'Request timed out.' : 'Could not connect.';
    setReply(thinkEl, '<div class="error-msg">' + msg + '</div><button class="retry-btn" onclick="retryQuestion(\'' + q.replace(/'/g,"\\'") + '\')">Try again</button>');
  }

  btn.disabled = false;
}

function retryQuestion(q) {
  document.getElementById('inp').value = q;
  sendMsg();
}
